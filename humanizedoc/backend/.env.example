# ╔════════════════════════════════════════════════════════════════╗
# ║  HumanizeDOC — Environment Variables                         ║
# ╠════════════════════════════════════════════════════════════════╣
# ║  Copy this file to `.env` and fill in the blanks.            ║
# ╚════════════════════════════════════════════════════════════════╝

# Groq API key (required) — obtain from https://console.groq.com
GROQ_API_KEY=

# Google Gemini API key (optional fallback) — obtain from https://aistudio.google.com
GEMINI_API_KEY=

# Which LLM backend to use: "groq" (default) or "gemini"
HUMANIZER_BACKEND=groq

# Azure Blob Storage connection string (required)
AZURE_STORAGE_CONNECTION_STRING=

# Azure Blob container name for uploaded / processed documents
AZURE_BLOB_CONTAINER_NAME=humanizedoc-uploads

# Maximum upload file size in megabytes
MAX_FILE_SIZE_MB=15

# Maximum word count allowed per document
MAX_WORDS_PER_REQUEST=12000

# Target word count per chunk sent to the LLM
CHUNK_SIZE_WORDS=500

# Minutes before uploaded / processed files are auto-deleted from blob storage
FILE_EXPIRY_MINUTES=60

# Maximum document uploads allowed per IP address per day
RATE_LIMIT_PER_IP_PER_DAY=5
